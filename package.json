    "node-fetch": "^3.3.2",
    "sharp": "^0.33.5",
    "unist-util-visit": "^5.0.0"
  },
  "overrides": {
    "@astrolib/analytics": {
      "astro": "$astro"
    },
    "@astrolib/seo": {
      "astro": "$astro"
    },
    "sharp": "$sharp"
  },
  "devDependencies": {
    "@astro-community/astro-embed-youtube": "^0.5.10",
