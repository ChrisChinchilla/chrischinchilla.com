    "limax": "4.2.3",
    "mdast-util-to-string": "^4.0.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "reading-time": "^1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "svgo": "^4.0.1",
    "tailwindcss": "^4.3.0",
