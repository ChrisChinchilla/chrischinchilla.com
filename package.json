{
  "name": "chrischinchilla",
  "type": "module",
  "description": "Chris Chinchilla's personal website",
  "version": "1.2.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "buildv": "astro build --verbose",
    "preview": "astro preview",
    "astro": "astro",
    "format": "prettier -w .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:eslint": "eslint . --ext .js,.ts,.astro",
    "check": "astro check"
  },
  "dependencies": {
