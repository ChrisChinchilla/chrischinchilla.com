    "@fontsource/bitter": "^5.2.10",
    "@iconify-json/carbon": "^1.2.21",
    "@iconify-json/fa": "^1.2.2",
    "@iconify-json/flat-color-icons": "^1.2.3",
    "@iconify-json/fluent": "^1.2.47",
    "@iconify-json/ph": "^1.2.2",
    "@iconify-json/ri": "^1.2.10",
    "@iconify-json/simple-icons": "^1.2.82",
    "@iconify-json/simple-line-icons": "^1.2.1",
    "@iconify-json/tabler": "^1.2.35",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
