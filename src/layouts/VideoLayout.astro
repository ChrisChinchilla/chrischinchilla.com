---
import Layout from '~/layouts/BaseLayout.astro';
import Header from '~/components/widgets/Header.astro';
import Footer from '~/components/widgets/Footer.astro';
import Announcement from '~/components/widgets/Announcement.astro';
import Breadcrumb from '~/components/common/Breadcrumb.astro';
import StructuredData from '~/components/common/StructuredData.astro';
import { YouTube } from "@astro-community/astro-embed-youtube";
import { MetaSEO } from '~/types';
import { SITE } from '~/config.mjs';

const { video } = Astro.props;
const snippet = video.snippet;

const thumbnail =
  snippet.thumbnails?.maxres?.url ||
  snippet.thumbnails?.high?.url ||
  snippet.thumbnails?.medium?.url ||
  snippet.thumbnails?.default?.url;

const canonical = new URL(Astro.url.pathname, SITE.origin).toString();

const meta: MetaSEO = {
  title: snippet.title,
  description: snippet.description.slice(0, 400),
  image: thumbnail,
  ogType: 'video.other',
  canonical,
};

function linkifyDescription(text: string, videoId: string): string {
  const escaped = text
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;');
  return escaped
    .replace(/\n/g, '<br>')
    .replace(/(https?:\/\/[^\s<]+)/g, (match) => {
      const safeHref = match.replace(/"/g, '&quot;');
      return `<a href="${safeHref}" target="_blank" rel="noopener noreferrer">${match}</a>`;
    })
    .replace(/\b(\d{1,2}:\d{2}(?::\d{2})?)\b/g, (match) => {
      const parts = match.split(':').map(Number);
      const seconds = parts.length === 3
        ? parts[0] * 3600 + parts[1] * 60 + parts[2]
        : parts[0] * 60 + parts[1];
      const safeVideoId = String(videoId).replace(/"/g, '&quot;');
      return `<a href="https://youtu.be/${safeVideoId}?t=${seconds}" target="_blank" rel="noopener noreferrer">${match}</a>`;
    });
}

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Videos', href: '/videos' },
  { label: snippet.title },
];
---

<Layout {meta}>
  <Fragment slot="head">
    <StructuredData type="VideoObject" data={{
      title: snippet.title,
      description: snippet.description,
      thumbnailUrl: thumbnail,
      uploadDate: snippet.publishedAt,
      videoId: snippet.resourceId.videoId,
      canonical,
    }} />
  </Fragment>
  <Announcement />
  <Header />
  <main>
    <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl">
      <Breadcrumb items={breadcrumbItems} />
      <h1 class="font-bold font-heading text-3xl md:text-4xl leading-tighter tracking-tighter mb-6">{snippet.title}</h1>
      <div
        class="mx-auto prose prose-lg max-w-4xl dark:prose-invert dark:prose-headings:text-slate-300 prose-md prose-headings:font-heading prose-headings:leading-tighter prose-headings:tracking-tighter prose-headings:font-bold prose-a:text-primary-600 dark:prose-a:text-primary-400"
      >
        <article class="max-w-md mx-auto md:max-w-none grid gap-6 md:gap-8 md:grid-cols-2">
          <div class="overflow-hidden rounded drop-shadow-lg">
            <YouTube id={snippet.resourceId.videoId} />
          </div>
          <div class="mt-2">
            <p set:html={linkifyDescription(snippet.description, snippet.resourceId.videoId)} />
            {snippet.publishedAt && (
              <p class="text-sm text-gray-500 dark:text-gray-400 mt-4">
                Published: {new Date(snippet.publishedAt).toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' })}
              </p>
            )}
          </div>
        </article>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
