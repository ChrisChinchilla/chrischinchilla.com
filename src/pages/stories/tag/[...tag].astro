---
import Layout from '~/layouts/PageLayoutNoBG.astro';
import Headline from '~/components/blog/Headline.astro';
import Story from '~/components/Story.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { groupTagsBySlug } from '~/utils/permalinks';

export async function getStaticPaths() {
  const allStories = await getCollection('stories');
  const allTags = allStories.map((story) => story.data.tags ?? []).flat();
  const slugToTags = groupTagsBySlug(allTags);

  return [...slugToTags.entries()].map(([slug, originalTags]) => {
    const filteredStories = allStories.filter((story) =>
      story.data.tags?.some((t) => originalTags.has(t))
    );
    const displayTag = [...originalTags].sort()[0];
    return {
      params: { tag: slug },
      props: { stories: filteredStories, originalTag: displayTag },
    };
  });
}

const { stories, originalTag } = Astro.props as { stories: CollectionEntry<'stories'>[], originalTag: string };
const meta = {
  title: originalTag,
  description: `Stories tagged with ${originalTag}`,
  noindex: true,
};
---

<Layout {meta}>
  <section class="px-4 py-16 mx-auto max-w-6xl lg:py-20">
    <Headline subtitle={meta.description}>
      {meta.title}
    </Headline>
    <div class="grid gap-6 row-gap-5 md:grid-cols-2 lg:grid-cols-3 -mb-6">
      {stories.map((story) => <Story story={story} />)}
    </div>
  </section>
</Layout>
