---
import Layout from '~/layouts/PageLayoutNoBG.astro';
import Headline from '~/components/blog/Headline.astro';
import Post from '~/components/Post.astro';
import { getCollection } from 'astro:content';
import { cleanSlug } from '~/utils/permalinks';

// TODO: Paginate 😱
export async function getStaticPaths() {
  const allPosts = await getCollection('posts');
  const allTags = allPosts.map((post) => post.data.tags ?? []).flat();

  // Group original tags by their slugified form to handle mixed casing
  const slugToTags = new Map<string, Set<string>>();
  for (const tag of allTags) {
    const slug = cleanSlug(tag);
    if (!slugToTags.has(slug)) slugToTags.set(slug, new Set());
    slugToTags.get(slug)!.add(tag);
  }

  return [...slugToTags.entries()].map(([slug, originalTags]) => {
    const filteredPosts = allPosts.filter((post) =>
      post.data.tags?.some((t) => originalTags.has(t))
    );
    const displayTag = [...originalTags].sort()[0];
    return {
      params: { tag: slug },
      props: { posts: filteredPosts, originalTag: displayTag },
    };
  });
}

const { posts, originalTag } = Astro.props;
const meta = {
  title: originalTag,
  description: `Blog posts tagged with ${originalTag}`,
  // canonical: post.canonical || url,
  // image: await findImage(post.image),
  // noindex: BLOG?.post?.noindex,
  // ogType: 'article',
};
---

<Layout {meta}>
  <section class="px-4 py-16 mx-auto max-w-6xl lg:py-20">
    <Headline subtitle={meta.description}>
      {meta.title}
    </Headline>
    <div class="grid gap-6 row-gap-5 md:grid-cols-2 lg:grid-cols-3 -mb-6">
      {posts.map((post) => <Post post={post} />)}
    </div>
  </section>
</Layout>
